{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@war-tracker/types": ["packages/types/src"],
      "@war-tracker/validation": ["packages/validation/src"],
      "@war-tracker/config": ["packages/config/src"],
      "@war-tracker/db": ["packages/db/src"],
      "@war-tracker/ingest": ["packages/ingest/src"]
    }
  }
}
